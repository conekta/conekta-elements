{
  "name": "@conekta/elements",
  "version": "0.0.1-beta.10",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/npm/index.cjs.js",
  "module": "./dist/npm/index.es.js",
  "types": "./dist/entries/npm/index.d.ts",
  "typesVersions": {
    "*": {
      "orchestrator": [
        "./dist/entries/npm/orchestrator.d.ts"
      ],
      "applePay": [
        "./dist/entries/npm/applePay.d.ts"
      ],
      "*": [
        "./dist/entries/npm/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/entries/npm/index.d.ts",
      "import": "./dist/npm/index.es.js",
      "require": "./dist/npm/index.cjs.js"
    },
    "./orchestrator": {
      "types": "./dist/entries/npm/orchestrator.d.ts",
      "import": "./dist/npm/orchestrator.es.js",
      "require": "./dist/npm/orchestrator.cjs.js"
    },
    "./applePay": {
      "types": "./dist/entries/npm/applePay.d.ts",
      "import": "./dist/npm/applePay.es.js",
      "require": "./dist/npm/applePay.cjs.js"
    },
    "./googlePay": {
      "types": "./dist/entries/npm/googlePay.d.ts",
      "import": "./dist/npm/googlePay.es.js",
      "require": "./dist/npm/googlePay.cjs.js"
    },
    "./cdn/orchestrator": {
      "import": "./dist/cdn/orchestrator.iife.js"
    }
  },
  "scripts": {
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run build:types && npm run build:npm && npm run build:cdn",
    "build:npm": "vite build",
    "build:cdn": "vite build -c vite.config.cdn.ts",
    "dev": "vite"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "@types/react": "^19.2.13",
    "@vitejs/plugin-react": "^5.1.3",
    "path": "^0.12.7",
    "typescript": "~5.9.3",
    "vite": "^7.3.1"
  },
  "dependencies": {
    "react": "^18.3.1",
    "shared": "file:../../shared/build/dist/js/developmentLibrary",
    "zoid": "9.0.80"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/conekta/conekta-elements.git",
    "directory": "webApp/packages/elements"
  }
}
