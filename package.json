{
  "name": "conekta-elements",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "webApp",
    "shared/build/dist/js/developmentLibrary"
  ],
  "scripts": {
    "build": "cd webApp && npm run build",
    "start": "cd webApp && npm run start",
    "publish-dry-run": "cd webApp && npm publish --dry-run",
    "prepublishOnly": "cd webApp && npm run build",
    "publish-app": "cd webApp && npm publish",
    "sync-version": "VERSION=$(grep '^conekta.version=' gradle.properties | cut -d'=' -f2) && cd webApp && npm --no-git-tag-version --allow-same-version version \"$VERSION\"",
    "prepare": "npm run sync-version && make js-build"
  }
}
