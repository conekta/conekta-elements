// Local development settings — do NOT check into version control
// Copy this file to Local.xcconfig and fill in your values
DEVELOPMENT_TEAM = YOUR_TEAM_ID
CONEKTA_PUBLIC_KEY = YOUR_PUBLIC_KEY_HERE
CONEKTA_CHECKOUT_REQUEST_ID = YOUR_CHECKOUT_REQUEST_ID_HERE
CONEKTA_JWT_TOKEN = YOUR_JWT_TOKEN_HERE
CONEKTA_TOKENIZER_RSA_PUBLIC_KEY = YOUR_RSA_PUBLIC_KEY_HERE
CONEKTA_API_BASE_URL = https:$()/$()/api.conekta.io
CONEKTA_CHECKOUT_BASE_URL = https:$()/$()/services.conekta.io
